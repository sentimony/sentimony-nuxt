# Local dev env. Copy to .env/.env (gitignored) and fill in real values.
# Personal overrides go to .env/.env.local (also gitignored).

# Supabase Dashboard → Project Settings → API
# Canonical Nuxt names (NUXT_PUBLIC_SUPABASE_URL / NUXT_PUBLIC_SUPABASE_KEY) also work.
SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
SUPABASE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>
# Server-side only, NEVER expose to client bundle
SUPABASE_SECRET_KEY=<SUBSTITUTE_SUPABASE_SECRET_KEY>

# GitHub Personal Access Token for Claude Code CLI (local use only).
# Generate at https://github.com/settings/tokens - scopes: repo, read:org.
# Belongs in .env.local (personal), not .env (team default).
PAT_FOR_CLAUDE_CODE=<GITHUB_PERSONAL_ACCESS_TOKEN>
