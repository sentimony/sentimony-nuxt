    "@nuxt/image": "^2.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/robots": "^6.0.7",
    "@nuxtjs/sitemap": "^8.0.13",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "nuxt": "^4.4.2",
    "swiper": "^12.1.3",
    "v-wave": "^3.0.4"
  },
  "engines": {
    "node": "24.15.0",
    "npm": "11.12.1"
