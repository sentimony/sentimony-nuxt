{
  "name": "sentimony-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt build",
    "dev": "node --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt dev",
    "generate": "node --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt generate",
    "preview": "node --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt preview",
    "postinstall": "nuxt prepare",
    "sync:firebase": "npx -y firebase-tools@15 database:set / public/data/sentimony-db-export.json -P sentimony-db -f",
    "sync:supabase": "node --env-file-if-exists=.env/.env.local scripts/sync-supabase.mjs",
    "deploy:stage": "npm run sync:firebase && npx -y netlify-cli@26 deploy --alias stage --context deploy-preview",
    "deploy:prod": "npm run sync:firebase && npx -y netlify-cli@26 deploy --prod --context production"
  },
  "devDependencies": {
    "@types/node": "^25.9.0"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/supabase": "^2.0.8",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@supabase/supabase-js": "^2.106.0",
    "nuxt": "^4.4.6",
    "swiper": "^12.1.4",
    "v-wave": "^3.0.4"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.0"
  }
}
