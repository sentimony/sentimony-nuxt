{
  "name": "sentimony-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "TMPDIR=/tmp node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt build",
    "dev": "TMPDIR=/tmp node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt dev",
    "generate": "TMPDIR=/tmp node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt generate",
    "preview": "TMPDIR=/tmp node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt preview",
    "postinstall": "TMPDIR=/tmp node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local node_modules/.bin/nuxt prepare",
    "sync:firebase": "node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local scripts/sync-firebase.mjs",
    "sync:supabase": "node --env-file-if-exists=.env/.env --env-file-if-exists=.env/.env.local scripts/sync-supabase.mjs",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:unit": "vitest run",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "web-debug": "node scripts/web-debug.mjs",
    "deploy:stage": "npm run netlify:stage",
    "deploy:prod": "npm run netlify:prod",
    "netlify:stage": "npx -y dotenv-cli@11 -e .env/.env.local -e .env/.env -- npx -y netlify-cli@26 deploy --alias stage --context deploy-preview",
    "netlify:prod": "npx -y dotenv-cli@11 -e .env/.env.local -e .env/.env -- npx -y netlify-cli@26 deploy --prod --context production"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/simple-icons": "^1.2.89",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/supabase": "^2.0.9",
    "@supabase/supabase-js": "^2.110.2",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "flag-icons": "^7.5.0",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.1",
    "swiper": "^14.0.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "v-wave": "^3.1.1",
    "vee-validate": "^4.15.1",
    "vue-sonner": "^2.0.9"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.0"
  }
}
