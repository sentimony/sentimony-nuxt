{
  "name": "sentimony-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "node --env-file=.env.local node_modules/.bin/nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "sync:firebase": "firebase database:set / public/data/sentimony-db-export.json -P sentimony-db -f",
    "sync:supabase": "node --env-file=.env.local scripts/sync-supabase.mjs",
    "deploy:stage": "netlify deploy --alias stage --context deploy-preview",
    "deploy:prod": "netlify deploy --prod",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.10",
    "firebase-tools": "^15.16.0",
    "happy-dom": "^20.9.0",
    "netlify-cli": "^26.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/supabase": "^2.0.6",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@supabase/supabase-js": "^2.105.1",
    "nuxt": "^4.4.4",
    "swiper": "^12.1.4",
    "v-wave": "^3.0.4"
  },
  "engines": {
    "node": "v24.15.0",
    "npm": "11.12.1"
  }
}
